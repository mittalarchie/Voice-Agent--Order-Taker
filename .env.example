# SQLite file location, used by Prisma
DATABASE_URL="file:./dev.db"

# Free LLM provider (Groq) for the text simulator and the voice pipeline's
# reasoning/tool-calling. Get a free key (no credit card) at
# https://console.groq.com
GROQ_API_KEY=

# Optional overrides.
# LLM_PROVIDER=groq        # or "openai" if you'd rather pay for it
# LLM_MODEL=llama-3.3-70b-versatile

# Only needed if you set LLM_PROVIDER=openai above.
# OPENAI_API_KEY=
